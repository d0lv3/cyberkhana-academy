PORT=5002
MONGODB_URI=mongodb://localhost:27017/cyberkhana-academy
# REQUIRED — generate ≥32 random chars; the server refuses weak secrets in production
JWT_SECRET=change-this-in-production
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Dev-only mock session (ignored entirely when NODE_ENV=production)
ALLOW_DEV_LOGIN=false

# Google OAuth — Google Identity Services client id (same value as the frontend's VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Set to 1 when running behind a reverse proxy (nginx, cloudflared) in production
TRUST_PROXY=0
